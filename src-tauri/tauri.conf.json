{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gif-composer",
  "version": "0.1.0",
  "identifier": "com.gifcomposer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GIF 合成器",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "resources": {
      "dmg/macOS安装说明.txt": "macOS安装说明.txt"
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 460
        },
        "appPosition": {
          "x": 160,
          "y": 195
        },
        "applicationFolderPosition": {
          "x": 490,
          "y": 195
        }
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
